{
  "expo": {
    "name": "Lisaan — Apprendre l'arabe",
    "slug": "lisaan",
    "version": "0.19.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lisaan",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B3A2D"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lisaan.app",
      "buildNumber": "19",
      "requireFullScreen": false,
      "infoPlist": {
        "CFBundleAllowMixedLocalizations": true,
        "NSMicrophoneUsageDescription": "Lisaan utilisera le microphone pour les exercices de prononciation dans une version future.",
        "NSSpeechRecognitionUsageDescription": "Lisaan utilisera la reconnaissance vocale pour évaluer votre prononciation dans une version future.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.lisaan.app",
      "versionCode": 19,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1B3A2D"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-sqlite",
      "expo-localization",
      "./plugins/withPrivacyManifest",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0F624C"
        }
      ]
    ],
    "web": {
      "bundler": "metro"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c57ac55d-2bfc-4025-a5b7-6719bd9085a1"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c57ac55d-2bfc-4025-a5b7-6719bd9085a1"
    }
  }
}
